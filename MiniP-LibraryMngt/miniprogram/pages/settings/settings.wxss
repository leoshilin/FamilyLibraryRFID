/* 设置页面样式 */
.page {
  min-height: 100vh;
  background: #f2f2f7;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  height: 96rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e5e5ea;
  position: sticky;
  top: 0;
  z-index: 10;
}

/* 返回按钮 */
.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
}

.back-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

/* 微信风格返回箭头（CSS border 绘制） */
.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

/* 标题 */
.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  text-align: center;
  flex: 1;
}

/* 占位 */
.nav-right {
  min-width: 120rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 30rpx;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}
