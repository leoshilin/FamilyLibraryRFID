<view class="page">

<!-- 用户信息 -->

<view class="card user-card">

  <view class="user-info">

    <view class="avatar">
      👤
    </view>

    <view class="user-text">

      <text class="user-name">
        {{user.nickName}}
      </text>

      <text class="user-role">
        {{user.role}}
      </text>

    </view>

  </view>

</view>

<!-- 当前家庭 -->

<view
  class="card family-card"
  bindtap="onSwitchFamily"
>

  <view>

    <text class="card-title">
      当前家庭
    </text>

    <text class="family-name">
      {{family.name}}
    </text>

  </view>

  <text class="arrow">›</text>

</view>

<!-- 家庭统计 -->

<view class="section">

  <view class="section-header">

    <text class="section-title">
      家庭统计
    </text>

  </view>

  <view class="stat-grid">

    <view class="stat-item">

      <text class="stat-value">
        {{stats.bookshelfCount}}
      </text>

      <text class="stat-label">
        书架
      </text>

    </view>

    <view class="stat-item">

      <text class="stat-value">
        {{stats.bookCount}}
      </text>

      <text class="stat-label">
        图书
      </text>

    </view>

  </view>

</view>

<!-- 书架管理 -->

<view class="section">

  <view class="section-header">

    <text class="section-title">
      书架管理
    </text>

  </view>

  <block
    wx:for="{{bookshelves}}"
    wx:key="_id"
  >

    <view
      class="list-item"
      bindtap="onBookshelfTap"
      data-id="{{item._id}}"
    >

      <view>

        <text class="item-name">
          {{item.name}}
        </text>

        <text class="item-subtitle">
          {{item.bookCount}}册
        </text>

      </view>

      <text class="arrow">›</text>

    </view>

  </block>

  <view
    class="add-button"
    bindtap="onAddBookshelf"
  >
    ＋新增书架
  </view>

</view>

<!-- 家庭管理 -->

<view class="section">

  <view class="section-header">

    <text class="section-title">
      家庭管理
    </text>

  </view>

  <view
    class="list-item"
    bindtap="onRenameFamily"
  >

    <text>
      修改家庭名称
    </text>

    <text class="arrow">›</text>

  </view>

  <view
    class="list-item"
    bindtap="onSwitchFamily"
  >

    <text>
      切换家庭
    </text>

    <text class="arrow">›</text>

  </view>

</view>

<!-- 系统 -->

<view class="section">

  <view class="section-header">

    <text class="section-title">
      系统
    </text>

  </view>

  <view
    class="list-item"
    bindtap="onAbout"
  >

    <text>
      关于系统
    </text>

    <text class="arrow">›</text>

  </view>

</view>

</view>