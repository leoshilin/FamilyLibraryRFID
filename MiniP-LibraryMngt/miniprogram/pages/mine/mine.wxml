<view wx:if="{{!registered}}">

<view class="card user-card">

  <view class="user-info">

    <view class="avatar">
      👤
    </view>

    <view class="user-text">

      <text class="user-name">
        未注册用户
      </text>

      <text class="user-role">
        请先注册系统账号
      </text>

    </view>

  </view>

</view>

<view
  class="register-button"
  bindtap="onRegisterTap"
>
  注册用户
</view>

</view>

<view wx:if="{{registered}}">

<!-- 用户信息 -->

<view
  class="card user-card"
  bindtap="onEditUserTap"
>

  <view class="user-info">

    <view class="avatar">
      👤
    </view>

    <view class="user-text">

      <text class="user-name">
        {{user.nickName}}
      </text>

      <text class="user-role">
        已注册用户
      </text>

    </view>
    <text class="arrow">›</text>
  </view>

</view>

<!-- 当前家庭 -->

<view class="card family-card">

  <view>

    <text class="card-title">
      当前家庭
    </text>

    <text class="family-name">
      {{family ? family.name : '未加入家庭'}}
    </text>

  </view>

  <text class="arrow">›</text>

</view>

<!-- 后续统计区域 -->

</view>