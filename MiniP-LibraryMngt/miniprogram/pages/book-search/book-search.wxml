<view class="page">

<!-- ======================== -->
<!-- 检索方式 -->
<!-- ======================== -->
<view class="search-tabs">

  <view
    class="tab {{searchMode === 'isbn' ? 'active' : ''}}"
    data-mode="isbn"
    bindtap="onSearchModeChange">
    ISBN检索
  </view>

  <view
    class="tab {{searchMode === 'condition' ? 'active' : ''}}"
    data-mode="condition"
    bindtap="onSearchModeChange">
    条件检索
  </view>

</view>

<view
    wx:if="{{searchMode==='isbn'}}"
    class="isbn-panel">
<view class="isbn-search-row">

  <input
    class="isbn-input"
    placeholder="请输入ISBN或点击扫码"
    value="{{isbn}}"
    bindinput="onISBNInput"
    confirm-type="search"
    bindconfirm="doSearch"/>

<image
    class="scan-icon"
    src="/images/icons/scan.png"
    bindtap="onScanISBN"/>

<image
    class="search-icon"
    src="/images/icons/search.png"
    bindtap="doSearch"/>
    
</view>
</view>

<!-- ======================== -->
<!-- 条件检索 -->
<!-- ======================== -->

<block wx:if="{{searchMode === 'condition'}}">

<!-- 已折叠 -->
<view
  wx:if="{{conditionCollapsed}}"
  class="condition-summary">

  <view class="summary-header">
    <text class="summary-title">当前筛选</text>

    <text
      class="summary-edit"
      bindtap="expandConditionFilter">
      修改筛选 >
    </text>
  </view>

  <block
    wx:if="{{conditionSummary.length > 0}}">

    <block
      wx:for="{{conditionSummary}}"
      wx:key="label">

      <view class="summary-item">

        <text class="summary-label">
          {{item.label}}：
        </text>

        <text class="summary-value">
          {{item.value}}
        </text>

      </view>

    </block>

  </block>

  <view
    wx:else
    class="summary-item">

    <text class="summary-value">
      当前未设置筛选条件
    </text>

  </view>

</view>


<!-- 展开状态 -->
<view
  wx:else
  class="advanced-panel">

  <!-- 关键词 -->
  <view class="form-row">

    <text class="form-label">
      关键词
    </text>

    <input
      class="form-input"
      placeholder="输入书名或作者"
      value="{{keyword}}"
      bindinput="onKeywordInput"/>

  </view>


  <!-- 图书状态 -->
  <view class="form-row">

    <text class="form-label">
      图书状态
    </text>

    <picker
      mode="selector"
      range="{{statusOptions}}"
      value="{{statusIndex}}"
      bindchange="onStatusChange">

      <view class="form-picker">
        {{statusOptions[statusIndex]}}
      </view>

    </picker>

  </view>


  <!-- 上架时间 -->
  <view class="form-row">

    <text class="form-label">
      上架时间
    </text>

    <view class="date-row">

      <picker
        mode="date"
        bindchange="onStartDateChange">

        <view class="date-picker">
          {{startDate || '开始日期'}}
        </view>

      </picker>

      <text class="date-sep">
        至
      </text>

      <picker
        mode="date"
        bindchange="onEndDateChange">

        <view class="date-picker">
          {{endDate || '结束日期'}}
        </view>

      </picker>

    </view>

  </view>


  <!-- 书架 -->
  <view class="form-row">

    <text class="form-label">
      书架
    </text>

    <picker
      range="{{bookshelfOptions}}"
      range-key="name"
      value="{{bookshelfIndex}}"
      bindchange="onBookshelfChange">

      <view class="form-picker">
        {{bookshelfOptions[bookshelfIndex].name}}
      </view>

    </picker>

  </view>


  <!-- RFID 绑定 -->
  <view class="form-row">

    <text class="form-label">
      RFID绑定
    </text>

    <picker
      mode="selector"
      range="{{rfidBindOptions}}"
      value="{{rfidBindIndex}}"
      bindchange="onRfidBindChange">

      <view class="form-picker">
        {{rfidBindOptions[rfidBindIndex]}}
      </view>

    </picker>

  </view>


  <button
    class="confirm-btn"
    bindtap="doSearch">

    搜索

  </button>

</view>

</block>

<!-- ======================== -->
<!-- 图书列表 -->
<!-- ======================== -->
<scroll-view scroll-y class="list" lower-threshold="50" bindscrolltolower="onReachBottom">

  <view class="book-list">

    <block wx:for="{{books}}" wx:key="itemId">

      <view class="swipe-item">

        <!-- 图书信息 -->
        <view class="book-item {{item.inventoryStatus === 'off_stock' ? 'off-book' : ''}}" bindtap="onBookTap" data-index="{{index}}">

          <image class="cover" src="{{item.coverUrl}}" mode="aspectFill" />

          <view class="info">

            <view class="title-row">

              <text class="title">
                {{item.title}}
              </text>

              <text wx:if="{{item.inventoryStatus === 'off_stock'}}" class="off-tag">
                已下架
              </text>

            </view>

            <text class="author">
              {{item.authors}}
            </text>
            
            <!-- RFID 状态（4 态：已绑定显示TID / 未绑定 / 绑定中 / 重新绑定中），位于动态按钮上方 -->
            <view class="rfid-line">
              <text class="rfid-label">RFID</text>
              <text class="rfid-value {{item.bindInProgress ? 'rfid-progress' : ''}}">
                {{ item.bindInProgress ? (item.rfidTid ? '重新绑定中…' : '绑定中…') : (item.rfidTid ? item.rfidTid : '未绑定') }}
              </text>
            </view>
            
            </view>
            
            </view>

        <!-- 展开按钮 -->
        <view class="actions" wx:if="{{currentExpandedId === item.itemId}}">

          <!-- 上架图书 -->
          <block wx:if="{{item.inventoryStatus === 'in_stock'}}">

            <view class="btn detail" catchtap="handleDetail" data-index="{{index}}">
              详情
            </view>

            <view class="btn off" catchtap="handleOff" data-index="{{index}}">
              下架
            </view>

            <!-- RFID 区域：按 4 态渲染（仅有权限时显示对应按钮） -->
            <block wx:if="{{canBind || canUnbind}}">
              <!-- 未绑定：绑定按钮（A 可点 / B 禁用并提示进行中） -->
              <view
                wx:if="{{canBind && !item.rfidTid}}"
                class="btn rfid {{item.bindInProgress || bindStatusLoading ? 'disabled' : ''}}"
                catchtap="handleBind"
                data-index="{{index}}">
                绑定RFID
              </view>

              <!-- 已绑定：解绑 + 重新绑定（C 可点 / D 禁用并提示进行中） -->
              <block wx:if="{{item.rfidTid}}">
                <view
                  wx:if="{{canUnbind}}"
                  class="btn rfid-unbind {{item.bindInProgress || bindStatusLoading ? 'disabled' : ''}}"
                  catchtap="handleUnbind"
                  data-index="{{index}}">
                  解绑
                </view>
                <view
                  wx:if="{{canBind}}"
                  class="btn rfid {{item.bindInProgress || bindStatusLoading ? 'disabled' : ''}}"
                  catchtap="handleBind"
                  data-index="{{index}}">
                  重新绑定
                </view>
              </block>

            </block>

            <!-- 寻书按钮：仅已绑定 RFID 且有权限时显示 -->
            <block wx:if="{{canFindBook && item.rfidTid}}">
              <view
                class="btn find-book"
                catchtap="handleFindBook"
                data-index="{{index}}">
                寻书
              </view>
            </block>

          </block>

          <!-- 已下架 -->
          <block wx:elif="{{item.inventoryStatus === 'off_stock'}}">

            <view class="btn detail" catchtap="handleDetail" data-index="{{index}}">
              详情
            </view>

            <view class="btn on" catchtap="handleOn" data-index="{{index}}">
              重新上架
            </view>

            <view class="btn delete" catchtap="handleDelete" data-index="{{index}}">
              彻底删除
            </view>

          </block>

        </view>

      </view>

    </block>

    </view>

    </scroll-view>

    <!-- ======================== -->
    <!-- 固定底栏：检索状态提示（不随列表滚动，常驻页面底部） -->
    <!-- ======================== -->

    <view class="list-footer" wx:if="{{pageReady}}">

      <!-- 正在加载 -->

      <view class="loading-line" wx:if="{{loadingMore}}">

        <view class="loading-divider"></view>

        <text class="loading-text">
          正在加载更多图书...
        </text>

        <view class="loading-divider"></view>

      </view>

      <!-- 已全部显示 -->

      <view class="loading-line" wx:if="{{!loadingMore && !hasMore && books.length>0}}">
      
        <view class="loading-divider"></view>
      
        <text class="loading-text">
          已显示全部图书
        </text>
      
        <view class="loading-divider"></view>
      
      </view>
      
      <!-- 无数据 -->
      
      <view class="loading-line" wx:if="{{!loadingMore && books.length === 0}}">

        <view class="loading-divider"></view>

        <text class="loading-text">
          没有找到符合条件的图书
        </text>

        <view class="loading-divider"></view>

      </view>

    </view>

    </view>