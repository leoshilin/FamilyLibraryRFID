.page {
  padding-bottom: 40rpx;
}

/* ======================== */
/*  卡片                    */
/* ======================== */

.card {
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.user-card {
  margin-top: 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
}

.user-role {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.family-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.family-name-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.family-name {
  font-size: 30rpx;
  font-weight: bold;
}

/* ======================== */
/*  角色标签                 */
/* ======================== */

.role-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  font-weight: bold;
}

.role-OWNER {
  background: #fff3e0;
  color: #e65100;
}

.role-MEMBER {
  background: #e3f2fd;
  color: #1565c0;
}

.role-GUEST {
  background: #f3e5f5;
  color: #7b1fa2;
}

/* ======================== */
/*  区块                    */
/* ======================== */

.section {
  background-color: #f7f5e6;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin: 40rpx 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #000;
}

.add-link {
  font-size: 26rpx;
  color: #576b95;
}

/* ======================== */
/*  列表项                   */
/* ======================== */

.list-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 10rpx 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
}

.item-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #576b95;
  padding: 8rpx;
}

.action-delete {
  color: #e74c3c;
}

.empty-tip {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* ======================== */
/*  弹窗                    */
/* ======================== */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.modal-card {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 80rpx;
  max-height: 60vh;
  background: #ffffff;
  border-radius: 24rpx;
  z-index: 101;
  display: flex;
  flex-direction: column;
}

.modal-form {
  top: 30%;
  bottom: auto;
  max-height: none;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 20rpx 30rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

/* ======================== */
/*  家庭选择器               */
/* ======================== */

.family-picker-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.family-picker-item:last-child {
  border-bottom: none;
}

.family-current {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.picker-item-main {
  display: flex;
  align-items: center;
}

.picker-item-name {
  font-size: 30rpx;
  font-weight: bold;
}

.current-badge {
  font-size: 20rpx;
  color: #07c160;
  margin-left: 16rpx;
  padding: 4rpx 14rpx;
  background: #e8f8ef;
  border-radius: 8rpx;
}

.picker-item-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

/* ======================== */
/*  表单                     */
/* ======================== */

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* ======================== */
/*  按钮                     */
/* ======================== */

.btn-primary {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 12rpx;
}

.btn-secondary {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.register-button {
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
}

.arrow {
  font-size: 36rpx;
  color: #bbb;
  margin-left: 20rpx;
}

/* ======================== */
/*  统计（预留）             */
/* ======================== */

.stat-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 42rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}
